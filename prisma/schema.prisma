generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["seo"]
}

model Site {

  id             String   @id @default(cuid())
  name           String
  domain         String   @unique
  wpUrl          String
  wpUser         String
  wpAppPassword  String   @db.Text
  gscSiteUrl     String
  language       String   @default("he")
  niche          String?
  brandTone      String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pages          Page[]
  keywords       Keyword[]
  opportunities  Opportunity[]
  articles       Article[]
  performances   Performance[]
  gscTokens      GscToken?
  intentAnalyses IntentAnalysis[]
  topicMap       TopicMap?
  experiments    Experiment[]
  contentGaps    ContentGap[]
  revenueData    RevenueData[]
  articleRevenues ArticleRevenue[]
  geoOptimizations GeoOptimization[]
  linkEdges           LinkEdge[]
  performanceSnapshots PerformanceSnapshot[]
  changeLogs           ChangeLog[]
  siteBI               SiteBI[]
  successPatterns      SiteSuccessPattern[]
  coreWebVitals        CoreWebVitals[]
  imageVariants        ImageVariant[]
  @@schema("seo")
}

model GscToken {

  id           String   @id @default(cuid())
  siteId       String   @unique
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  @@schema("seo")
}

model Page {

  id          String   @id @default(cuid())
  siteId      String
  url         String
  title       String?
  wpPostId    Int?
  status      String   @default("active")
  lastCrawled DateTime?
  isOrphan    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keywordPages KeywordPage[]
  performances Performance[]
  articles     Article[]
  sourceLinks  LinkEdge[]    @relation("SourceLinks")
  targetLinks  LinkEdge[]    @relation("TargetLinks")

  @@unique([siteId, url])
  @@index([siteId, status])
  @@schema("seo")
}

model Keyword {

  id           String   @id @default(cuid())
  siteId       String
  keyword      String
  searchVolume Int?
  difficulty   Float?
  createdAt    DateTime @default(now())

  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keywordPages  KeywordPage[]
  opportunities Opportunity[]

  @@unique([siteId, keyword])
  @@index([siteId])
  @@schema("seo")
}

model KeywordPage {

  keywordId String
  pageId    String
  isPrimary Boolean @default(false)

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([keywordId, pageId])
  @@schema("seo")
}

model Opportunity {

  id          String   @id @default(cuid())
  siteId      String
  keywordId   String?
  pageId      String?
  type        String
  priority    Float    @default(0)
  status      String   @default("pending")
  query       String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  brief       Json?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword  Keyword?  @relation(fields: [keywordId], references: [id])
  articles Article[]

  @@index([siteId, status])
  @@index([siteId, priority])
  @@schema("seo")
}

model Article {

  id                String    @id @default(cuid())
  siteId            String
  opportunityId     String?
  pageId            String?
  wpPostId          Int?
  status            String    @default("pending")
  title             String?
  slug              String?
  content           String?   @db.Text
  excerpt           String?   @db.Text
  metaTitle         String?
  metaDescription   String?
  schema            Json?
  primaryKeyword    String?
  secondaryKeywords String[]
  contentBrief      Json?
  wordCount         Int?
  wpPostUrl         String?
  errorLog          String?   @db.Text
  audience          String?
  imagePrompt       String?   @db.Text
  imageHistory      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  publishedAt       DateTime?

  site        Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  opportunity Opportunity?  @relation(fields: [opportunityId], references: [id])
  page        Page?         @relation(fields: [pageId], references: [id])
  images      ArticleImage[]
  titleVariants TitleVariant[]
  experiments   Experiment[]
  contentGaps   ContentGap[]
  revenueData   RevenueData[]
  articleRevenue ArticleRevenue?
  geoOptimization GeoOptimization?
  topicArticles TopicArticle[]
  changeLogs    ChangeLog[]
  imageVariants ImageVariant[]

  @@index([siteId, status])
  @@schema("seo")
}

model ArticleImage {

  id        String   @id @default(cuid())
  articleId String
  type      String
  url       String?
  wpMediaId Int?
  altText   String?
  filename  String?
  prompt    String?  @db.Text
  position  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@schema("seo")
}

model Performance {

  id          String   @id @default(cuid())
  siteId      String
  pageId      String?
  query       String
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)

  site Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  page Page? @relation(fields: [pageId], references: [id])

  @@unique([siteId, query, date])
  @@index([siteId, date])
  @@index([pageId, date])
  @@schema("seo")
}

model SeoAudit {

  id         String   @id @default(cuid())
  siteId     String
  url        String
  score      Int
  issues     Json
  createdAt  DateTime @default(now())

  @@index([siteId])
  @@schema("seo")
}

// ─── Intent Engine ───────────────────────────────────────
model IntentAnalysis {

  id              String   @id @default(cuid())
  siteId          String
  query           String
  primaryIntent   String
  subIntents      String[]
  journeyStage    String
  emotionalAngles Json
  dominantFormat  String
  competitorGaps  Json
  winningOutline  Json
  serpFeatures    String[]
  mobilePriority  Boolean  @default(false)
  hookSuggestion  String?  @db.Text
  createdAt       DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, query])
  @@index([siteId])
  @@schema("seo")
}

// ─── Topical Authority Engine ─────────────────────────────
model TopicMap {

  id            String   @id @default(cuid())
  siteId        String   @unique
  niche         String
  pillars       Json
  clusters      Json
  coverageScore Float    @default(0)
  totalArticles Int      @default(0)
  missingTopics Json
  writingOrder  Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  site     Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  articles TopicArticle[]
  @@schema("seo")
}

model TopicArticle {

  id           String   @id @default(cuid())
  topicMapId   String
  articleId    String?
  keyword      String
  type         String
  pillarId     String?
  cluster      String
  status       String   @default("planned")
  priority     Int      @default(0)
  writingOrder Int      @default(0)
  createdAt    DateTime @default(now())

  topicMap TopicMap @relation(fields: [topicMapId], references: [id], onDelete: Cascade)
  article  Article? @relation(fields: [articleId], references: [id])
  @@schema("seo")
}

// ─── CTR Engine ────────────────────────────────────────────
model TitleVariant {

  id          String   @id @default(cuid())
  articleId   String
  title       String
  metaTitle   String?
  predictedCtr Float?
  actualCtr   Float?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  isActive    Boolean  @default(false)
  isWinner    Boolean  @default(false)
  reasoning   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  @@schema("seo")
}

// ─── Experiment Engine ────────────────────────────────────
model Experiment {

  id           String   @id @default(cuid())
  siteId       String
  articleId    String?
  type         String
  name         String
  hypothesis   String   @db.Text
  variantA     Json
  variantB     Json
  metric       String
  status       String   @default("running")
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  winnerId     String?
  significance Float?
  results      Json?
  createdAt    DateTime @default(now())

  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id])

  @@index([siteId, status])
  @@schema("seo")
}

// ─── Refresh Engine v2 ────────────────────────────────────
model ContentGap {

  id          String   @id @default(cuid())
  articleId   String
  siteId      String
  gapType     String
  query       String
  missingSection String? @db.Text
  suggestedText  String? @db.Text
  priority    Float    @default(0)
  status      String   @default("pending")
  appliedAt   DateTime?
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([articleId, status])
  @@index([siteId, priority])
  @@schema("seo")
}

// ─── Revenue Engine ───────────────────────────────────────
model RevenueData {

  id          String   @id @default(cuid())
  siteId      String
  date        DateTime @db.Date
  orderId     String?
  revenue     Float    @default(0)
  product     String?
  sourceUrl   String?
  medium      String?
  articleId   String?
  createdAt   DateTime @default(now())

  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id])

  @@index([siteId, date])
  @@index([articleId])
  @@schema("seo")
}

model ArticleRevenue {

  id              String   @id @default(cuid())
  articleId       String   @unique
  siteId          String
  totalRevenue    Float    @default(0)
  totalOrders     Int      @default(0)
  avgOrderValue   Float    @default(0)
  conversionRate  Float    @default(0)
  revenuePerVisit Float    @default(0)
  lastCalculated  DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, totalRevenue])
  @@schema("seo")
}

// ─── GEO Engine (Generative Engine Optimization) ─────────
model GeoOptimization {

  id                String   @id @default(cuid())
  articleId         String
  siteId            String
  directAnswers     Json
  entityMap         Json
  citationScore     Float?
  aiReadabilityScore Float?
  structuredQA      Json
  featuredSnippet   String?  @db.Text
  aiSearchSignals   Json
  lastAnalyzed      DateTime @default(now())
  createdAt         DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([articleId])
  @@schema("seo")
}

// ─── Internal Link Graph ──────────────────────────────────
model LinkEdge {

  id           String   @id @default(cuid())
  siteId       String
  sourcePageId String
  targetPageId String
  anchorText   String
  isAutoAdded  Boolean  @default(false)
  pageRankFlow Float    @default(0)
  createdAt    DateTime @default(now())

  site       Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourcePage Page @relation("SourceLinks", fields: [sourcePageId], references: [id], onDelete: Cascade)
  targetPage Page @relation("TargetLinks", fields: [targetPageId], references: [id], onDelete: Cascade)

  @@unique([sourcePageId, targetPageId])
  @@index([siteId])
  @@index([targetPageId])
  @@schema("seo")
}

// ─── Data Layer — Historical Storage ─────────────────────
model PerformanceSnapshot {

  id          String   @id @default(cuid())
  siteId      String
  pageId      String?
  url         String
  snapshotDate DateTime @db.Date
  period      String   @default("daily")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  topQuery    String?
  queryCount  Int      @default(0)
  createdAt   DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, url, snapshotDate, period])
  @@index([siteId, snapshotDate])
  @@index([pageId])
  @@schema("seo")
}

model ChangeLog {

  id          String   @id @default(cuid())
  siteId      String
  articleId   String?
  pageId      String?
  changeType  String
  field       String?
  valueBefore String?  @db.Text
  valueAfter  String?  @db.Text
  metadata    Json?
  performanceImpact Json?
  measuredAt  DateTime?
  createdAt   DateTime @default(now())

  site    Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id])

  @@index([siteId, changeType])
  @@index([articleId])
  @@schema("seo")
}

model SiteBI {

  id              String   @id @default(cuid())
  siteId          String
  reportDate      DateTime @db.Date
  reportType      String
  data            Json
  insights        Json?
  createdAt       DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, reportDate, reportType])
  @@index([siteId, reportType])
  @@schema("seo")
}

// ─── Learning Engine ──────────────────────────────────────
model SiteSuccessPattern {

  id              String   @id @default(cuid())
  siteId          String
  patternType     String
  patternKey      String
  patternValue    String   @db.Text
  confidence      Float    @default(0)
  supportingCount Int      @default(0)
  avgCtrLift      Float    @default(0)
  avgPositionGain Float    @default(0)
  examples        Json
  lastUpdated     DateTime @default(now())
  createdAt       DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, patternType, patternKey])
  @@index([siteId, confidence])
  @@schema("seo")
}

// ─── Technical SEO — Core Web Vitals ─────────────────────
model CoreWebVitals {

  id          String   @id @default(cuid())
  siteId      String
  url         String
  device      String   @default("mobile")
  lcp         Float?
  fid         Float?
  cls         Float?
  ttfb        Float?
  fcp         Float?
  tbt         Float?
  performanceScore Int?
  measuredAt  DateTime @default(now())
  source      String   @default("pagespeed")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, measuredAt])
  @@index([url])
  @@schema("seo")
}

// ─── Image A/B Testing ────────────────────────────────────
model ImageVariant {

  id          String   @id @default(cuid())
  articleId   String
  siteId      String
  type        String
  prompt      String   @db.Text
  url         String?
  wpMediaId   Int?
  style       String?
  isActive    Boolean  @default(false)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@schema("seo")
}
